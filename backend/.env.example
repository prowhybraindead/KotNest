HOST=0.0.0.0
PORT=3000
DATABASE_PATH=./data/kotnest.db

# Cache TTL (seconds)
SUBSCRIPTION_CACHE_TTL_SECONDS=45
EXCHANGE_RATE_CACHE_TTL_SECONDS=21600

# Set this to a strong random value in production.
# If empty, backend allows anonymous sync (good for initial local setup).
API_TOKEN=
ALLOW_ANONYMOUS_SYNC=true

# Optional CORS list separated by commas. Keep empty to allow all.
CORS_ORIGINS=

# Exchange rate upstream
FRANKFURTER_BASE_URL=https://api.frankfurter.dev/v1
OPEN_ER_API_BASE_URL=https://open.er-api.com/v6

# AI Brand + Policy
AI_BRAND_NAME=Nesty
AI_RULES_VERSION=2026-05-kotnest-safe-finance-v1
AI_TIMEOUT_SECONDS=14

# Default virtual model shown in app (Nesty routes to real providers internally)
AI_DEFAULT_VIRTUAL_MODEL=nesty-atlas-combined-1.0

# Default provider/model routing preferences
AI_DEFAULT_PROVIDER=groq
AI_DEFAULT_GROQ_MODEL=llama-3.3-70b-versatile
AI_DEFAULT_NIMS_MODEL=google/gemma-3n-e4b-it

# Groq (OpenAI-compatible)
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
# Groq model options:
# meta-llama/llama-4-scout-17b-16e-instruct
# llama-3.3-70b-versatile
# groq/compound
# qwen/qwen3-32b

# NVIDIA NIMs (OpenAI-compatible)
NVIDIA_NIMS_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIMS_API_KEY=
# NVIDIA model options:
# mistral-large-3-675b-instruct-2512
# minimax-m2.7
# gemma-3n-e4b-it

# Web search augmentation via DDGS (DuckDuckGo ecosystem)
AI_ENABLE_WEB_SEARCH=true
AI_WEB_SEARCH_MAX_RESULTS=5

# Market/time augmentation for AI context
AI_ENABLE_MARKET_SNAPSHOT=true
AI_MARKET_SNAPSHOT_TTL_SECONDS=120
AI_TIME_ZONE=Asia/Ho_Chi_Minh
YAHOO_FINANCE_BASE_URL=https://query1.finance.yahoo.com
AI_ENABLE_VN_FUEL_SNAPSHOT=true
AI_VN_FUEL_SNAPSHOT_TTL_SECONDS=900
VN_FUEL_SOURCE_URL=https://giaxanghomnay.com/

# Cloudflare Tunnel (optional but recommended for HTTPS)
# You can also place these in backend/cloudflare/.env
TUNNEL_ENABLED=1
TUNNEL_METRICS=127.0.0.1:20241
CLOUDFLARE_TUNNEL_TOKEN=
TUNNEL_AUTO_INSTALL_CLOUDFLARED=1
CLOUDFLARED_BIN_PATH=/home/container/.cloudflared/bin/cloudflared
CLOUDFLARED_LOG_PATH=./cloudflare/cloudflared.log
CLOUDFLARED_PID_PATH=./cloudflare/cloudflared.pid
