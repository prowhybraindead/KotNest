<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_main_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top Row: Logo & Monthly Total -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="KotNest"
            android:textColor="@color/widget_accent_aqua"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_month_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This month: 0 VND"
            android:textColor="@color/widget_text_primary_themed"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@color/widget_border_themed" />

    <!-- Center Content: Next Due Details -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_next_due_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Next upcoming due"
            android:textColor="@color/widget_text_secondary"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_next_due_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="No upcoming dues"
            android:textColor="@color/widget_text_primary_themed"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Bottom Row: Today and Overdue counts with colorful indicator boxes -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <!-- Today count indicator -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginEnd="16dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@color/widget_warning"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/widget_today_countText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today: 0"
                android:textColor="@color/widget_text_primary_themed"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Overdue count indicator -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@color/widget_danger"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/widget_overdue_countText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Overdue: 0"
                android:textColor="@color/widget_text_primary_themed"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/widget_status_line"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to open"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
